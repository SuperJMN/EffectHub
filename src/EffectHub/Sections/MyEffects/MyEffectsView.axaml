<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:myEffects="clr-namespace:EffectHub.Sections.MyEffects"
             xmlns:models="clr-namespace:EffectHub.Core.Models;assembly=EffectHub.Core"
             x:Class="EffectHub.Sections.MyEffects.MyEffectsView"
             x:DataType="myEffects:MyEffectsViewModel">

    <DockPanel Margin="24">
        <DockPanel DockPanel.Dock="Top" Margin="0,0,0,20">
            <TextBlock Text="My Effects" FontSize="28" FontWeight="Bold" VerticalAlignment="Center" />
            <Button Content="Import" Command="{Binding ImportCommand}" HorizontalAlignment="Right" />
        </DockPanel>

        <ListBox ItemsSource="{Binding Effects}" SelectedItem="{Binding SelectedEffect}">
            <ListBox.ItemTemplate>
                <DataTemplate x:DataType="models:Effect">
                    <Grid ColumnDefinitions="*,Auto" Margin="8">
                        <StackPanel Spacing="4">
                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="14" />
                            <TextBlock Text="{Binding Description}" Opacity="0.6" FontSize="12" MaxLines="1" TextTrimming="CharacterEllipsis" />
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="{Binding UpdatedAt, StringFormat='Updated: {0:g}'}" FontSize="11" Opacity="0.4" />
                                <TextBlock Text="{Binding Tags.Count, StringFormat='{}{0} tags'}" FontSize="11" Opacity="0.4" />
                            </StackPanel>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                            <Button Content="Export" Command="{Binding $parent[ListBox].((myEffects:MyEffectsViewModel)DataContext).ExportCommand}" CommandParameter="{Binding}" />
                            <Button Content="Duplicate" Command="{Binding $parent[ListBox].((myEffects:MyEffectsViewModel)DataContext).DuplicateCommand}" CommandParameter="{Binding}" />
                            <Button Content="Delete" Command="{Binding $parent[ListBox].((myEffects:MyEffectsViewModel)DataContext).DeleteCommand}" CommandParameter="{Binding Id}" />
                        </StackPanel>
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </DockPanel>
</UserControl>
