<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:gallery="clr-namespace:EffectHub.Sections.Gallery"
             xmlns:models="clr-namespace:EffectHub.Core.Models;assembly=EffectHub.Core"
             xmlns:behaviors="clr-namespace:EffectHub.Behaviors"
             xmlns:preview="clr-namespace:EffectHub.Controls.EffectPreview"
             x:Class="EffectHub.Sections.Gallery.GalleryView"
             x:DataType="gallery:GalleryViewModel">

    <Panel>
        <!-- Gallery grid -->
        <DockPanel Margin="24">
            <!-- Header -->
            <StackPanel DockPanel.Dock="Top" Spacing="16" Margin="0,0,0,20">
                <TextBlock Text="Shader Gallery" FontSize="28" FontWeight="Bold" />
                <TextBox Watermark="Search effects..." Text="{Binding SearchText}" />
            </StackPanel>

            <!-- Effects grid -->
            <ScrollViewer>
                <ItemsControl ItemsSource="{Binding Effects}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="models:Effect">
                            <Border Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}"
                                    CornerRadius="8"
                                    Padding="12"
                                    Margin="8"
                                    Width="240"
                                    MinHeight="180"
                                    Cursor="Hand">
                                <Interaction.Behaviors>
                                    <behaviors:TappedCommandBehavior
                                        Command="{Binding ((gallery:GalleryViewModel)DataContext).ViewDetailCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}" />
                                </Interaction.Behaviors>
                                <StackPanel Spacing="8">
                                    <!-- Live shader preview -->
                                    <preview:EffectPreviewControl Height="120"
                                                                   SkslCode="{Binding SkslCode}" />
                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="14" />
                                    <TextBlock Text="{Binding Description}"
                                               MaxLines="2"
                                               TextTrimming="CharacterEllipsis"
                                               Opacity="0.7"
                                               FontSize="12" />
                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                        <PathIcon Data="{StaticResource mdi-account}" Width="12" Height="12" Opacity="0.5" />
                                        <TextBlock Text="{Binding AuthorAlias}" FontSize="11" Opacity="0.5" />
                                        <Border IsVisible="{Binding HasCpuFallback}"
                                                Background="#44448844"
                                                CornerRadius="3"
                                                Padding="6,1"
                                                Margin="4,0,0,0">
                                            <TextBlock Text="CPU" FontSize="9" FontWeight="SemiBold" Opacity="0.8" />
                                        </Border>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </DockPanel>

        <!-- Detail overlay -->
        <Border IsVisible="{Binding IsDetailVisible}"
                Background="#E0000000"
                ZIndex="10">
            <Border Background="{DynamicResource SystemControlBackgroundAltHighBrush}"
                    CornerRadius="12"
                    Margin="40"
                    Padding="32"
                    MaxWidth="800"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    BoxShadow="0 8 32 0 #40000000">
                <DockPanel DataContext="{Binding SelectedEffect}" x:DataType="models:Effect">
                    <!-- Header with close button -->
                    <DockPanel DockPanel.Dock="Top" Margin="0,0,0,16">
                        <Button DockPanel.Dock="Right"
                                Content="&#xE711;"
                                FontFamily="Segoe MDL2 Assets"
                                Background="Transparent"
                                BorderThickness="0"
                                FontSize="16"
                                Cursor="Hand"
                                Command="{Binding ((gallery:GalleryViewModel)DataContext).CloseDetailCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" />
                        <TextBlock Text="{Binding Name}"
                                   FontSize="24"
                                   FontWeight="Bold"
                                   VerticalAlignment="Center" />
                    </DockPanel>

                    <!-- Action buttons at bottom -->
                    <StackPanel DockPanel.Dock="Bottom"
                                Orientation="Horizontal"
                                Spacing="12"
                                Margin="0,16,0,0"
                                HorizontalAlignment="Right">
                        <Button Content="Duplicate and Edit"
                                Classes="accent"
                                Padding="16,8"
                                Command="{Binding ((gallery:GalleryViewModel)DataContext).DuplicateAndEditCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                CommandParameter="{Binding}" />
                        <Button Content="Close"
                                Padding="16,8"
                                Command="{Binding ((gallery:GalleryViewModel)DataContext).CloseDetailCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" />
                    </StackPanel>

                    <!-- Scrollable content -->
                    <ScrollViewer>
                        <StackPanel Spacing="12">
                            <!-- Live shader preview -->
                            <preview:EffectPreviewControl Height="200"
                                                           SkslCode="{Binding SkslCode}" />

                            <!-- Description -->
                            <TextBlock Text="{Binding Description}"
                                       TextWrapping="Wrap"
                                       Opacity="0.8"
                                       FontSize="14" />

                            <!-- Metadata row -->
                            <StackPanel Orientation="Horizontal" Spacing="24">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <PathIcon Data="{StaticResource mdi-account}" Width="14" Height="14" Opacity="0.6" />
                                    <TextBlock Text="{Binding AuthorAlias}" FontSize="13" Opacity="0.7" />
                                </StackPanel>
                                <TextBlock Text="{Binding CreatedAt, StringFormat='{}{0:yyyy-MM-dd}'}"
                                           FontSize="13"
                                           Opacity="0.5" />
                            </StackPanel>

                            <!-- Tags -->
                            <ItemsControl ItemsSource="{Binding Tags}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel Orientation="Horizontal" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="x:String">
                                        <Border Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}"
                                                CornerRadius="4"
                                                Padding="8,4"
                                                Margin="0,0,6,4">
                                            <TextBlock Text="{Binding}" FontSize="12" Opacity="0.8" />
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <!-- Code label -->
                            <TextBlock Text="Shader Code"
                                       FontWeight="SemiBold"
                                       FontSize="14"
                                       Margin="0,8,0,4" />

                            <!-- Read-only code view -->
                            <Border Background="{DynamicResource SystemControlBackgroundBaseLowBrush}"
                                    CornerRadius="6"
                                    Padding="16">
                                <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                              MaxHeight="300">
                                    <TextBlock Text="{Binding SkslCode}"
                                               FontFamily="Cascadia Code, Consolas, Menlo, monospace"
                                               FontSize="13"
                                               TextWrapping="NoWrap"
                                               Opacity="0.9" />
                                </ScrollViewer>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </DockPanel>
            </Border>
        </Border>
    </Panel>
</UserControl>
