<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:editor="clr-namespace:EffectHub.Sections.Editor"
             xmlns:ae="clr-namespace:AvaloniaEdit;assembly=AvaloniaEdit"
             xmlns:b="clr-namespace:EffectHub.Behaviors"
             xmlns:preview="clr-namespace:EffectHub.Controls.EffectPreview"
             xmlns:converters="clr-namespace:EffectHub.Converters"
             xmlns:pg="clr-namespace:Zafiro.Avalonia.Controls.PropertyGrid;assembly=Zafiro.Avalonia"
             xmlns:pgvm="clr-namespace:Zafiro.Avalonia.Controls.PropertyGrid.ViewModels;assembly=Zafiro.Avalonia"
             x:Class="EffectHub.Sections.Editor.EditorView"
             x:DataType="editor:EditorViewModel">

    <UserControl.Resources>
        <pg:PropertyEditorSelector x:Key="UniformEditorSelector">
            <pg:PropertyEditorSelector.Editors>
                <DataTemplate x:Key="System.Double" DataType="pgvm:IPropertyItem">
                    <DockPanel>
                        <NumericUpDown DockPanel.Dock="Right" Value="{Binding Value}" Minimum="0" Maximum="1"
                                       Increment="0.01" FormatString="F2" Width="90" />
                        <Slider Value="{Binding Value}" Minimum="0" Maximum="1" TickFrequency="0.01" />
                    </DockPanel>
                </DataTemplate>
                <DataTemplate x:Key="System.Int32" DataType="pgvm:IPropertyItem">
                    <NumericUpDown Value="{Binding Value}" FormatString="0" />
                </DataTemplate>
                <DataTemplate x:Key="System.Boolean" DataType="pgvm:IPropertyItem">
                    <CheckBox IsChecked="{Binding Value}" />
                </DataTemplate>
                <DataTemplate x:Key="Avalonia.Media.Color" DataType="pgvm:IPropertyItem">
                    <ColorPicker Color="{Binding Value}" HorizontalAlignment="Stretch" />
                </DataTemplate>
            </pg:PropertyEditorSelector.Editors>
        </pg:PropertyEditorSelector>
    </UserControl.Resources>

    <Grid ColumnDefinitions="*,12,*" Margin="16">
        <!-- Left panel: Code editor -->
        <DockPanel Grid.Column="0">
            <!-- Toolbar -->
            <StackPanel DockPanel.Dock="Top" Spacing="8" Margin="0,0,0,12">
                <TextBlock Text="Shader Editor" FontSize="20" FontWeight="SemiBold" />
                <Grid ColumnDefinitions="*,8,*">
                    <TextBox Grid.Column="0" Watermark="Effect name" Text="{Binding EffectName}" />
                    <TextBox Grid.Column="2" Watermark="Tags (comma separated)" Text="{Binding Tags}" />
                </Grid>
                <TextBox Watermark="Description" Text="{Binding Description}" AcceptsReturn="True" MinHeight="48" />
            </StackPanel>

            <!-- Error panel -->
            <Border DockPanel.Dock="Bottom"
                    IsVisible="{Binding CompilationError, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                    Background="#44FF4444"
                    CornerRadius="4"
                    Padding="12"
                    Margin="0,8,0,0">
                <StackPanel Spacing="4">
                    <TextBlock Text="Compilation Error" FontWeight="SemiBold" Foreground="#FFFF6666" />
                    <TextBlock Text="{Binding CompilationError}" FontFamily="Cascadia Code,Consolas,monospace" FontSize="12" TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <!-- Save button -->
            <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Spacing="8" Margin="0,8,0,0" HorizontalAlignment="Right">
                <Button Content="New" Command="{Binding NewEffectCommand}" />
                <Button Content="Save" Command="{Binding SaveCommand}" Classes="accent" />
            </StackPanel>

            <!-- Code editor -->
            <ae:TextEditor Name="CodeEditor"
                           FontFamily="Cascadia Code,Consolas,monospace"
                           FontSize="13"
                           ShowLineNumbers="True"
                           Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}">
                <Interaction.Behaviors>
                    <b:TextEditorBindingBehavior Text="{Binding SkslCode}" />
                </Interaction.Behaviors>
            </ae:TextEditor>
        </DockPanel>

        <GridSplitter Grid.Column="1" ResizeDirection="Columns" />

        <!-- Right panel: Preview + Uniforms -->
        <DockPanel Grid.Column="2">
            <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="12" Margin="0,0,0,12">
                <TextBlock Text="Preview" FontSize="20" FontWeight="SemiBold" VerticalAlignment="Center" />
                <ComboBox ItemsSource="{Binding AvailableSurfaces}"
                          SelectedItem="{Binding SelectedSurface}"
                          MinWidth="150"
                          VerticalAlignment="Center" />
            </StackPanel>

            <!-- Uniforms panel with editable controls -->
            <Border DockPanel.Dock="Bottom"
                    Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
                    CornerRadius="4"
                    Padding="12"
                    Margin="0,8,0,0"
                    MaxHeight="300">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="Uniforms" FontWeight="SemiBold" FontSize="13" Margin="0,0,0,8" />
                    <ScrollViewer>
                        <ItemsControl ItemsSource="{Binding UniformPropertyItems}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="pgvm:IPropertyItem">
                                    <DockPanel Margin="0,4">
                                        <TextBlock Text="{Binding Name}"
                                                   FontFamily="Cascadia Code,Consolas,monospace"
                                                   Width="120"
                                                   VerticalAlignment="Center"
                                                   DockPanel.Dock="Left" />
                                        <ContentControl Content="{Binding}"
                                                        ContentTemplate="{StaticResource UniformEditorSelector}" />
                                    </DockPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </DockPanel>
            </Border>

            <!-- Preview surface -->
            <Border Background="{DynamicResource SystemControlBackgroundBaseLowBrush}"
                    CornerRadius="8"
                    ClipToBounds="True">
                <Panel>
                    <!-- Gradient test surface with live shader effect -->
                    <Border Name="PreviewSurface"
                            Background="{Binding SelectedSurface, Converter={x:Static converters:SurfaceConverters.TestSurfaceToBrush}}">
                        <Border.Effect>
                            <preview:DynamicShaderEffect SkslCode="{Binding SkslCode}" />
                        </Border.Effect>
                    </Border>

                    <!-- Status overlay -->
                    <Border VerticalAlignment="Top" HorizontalAlignment="Right" Margin="8"
                            Background="#88000000" CornerRadius="4" Padding="8,4">
                        <TextBlock FontSize="11">
                            <TextBlock.Text>
                                <MultiBinding StringFormat="{}Compiled: {0}">
                                    <Binding Path="IsCompiled" />
                                </MultiBinding>
                            </TextBlock.Text>
                        </TextBlock>
                    </Border>
                </Panel>
            </Border>
        </DockPanel>
    </Grid>
</UserControl>
