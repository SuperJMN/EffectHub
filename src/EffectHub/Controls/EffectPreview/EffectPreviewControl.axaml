<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:preview="clr-namespace:EffectHub.Controls.EffectPreview"
             x:Class="EffectHub.Controls.EffectPreview.EffectPreviewControl">
    <Border ClipToBounds="True" CornerRadius="4">
        <Border Name="PART_Surface">
            <Border.Background>
                <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
                    <GradientStop Color="#FF6B35" Offset="0" />
                    <GradientStop Color="#004E98" Offset="0.5" />
                    <GradientStop Color="#1A936F" Offset="1" />
                </LinearGradientBrush>
            </Border.Background>
            <Border.Effect>
                <preview:DynamicShaderEffect SkslCode="{Binding SkslCode, RelativeSource={RelativeSource AncestorType=preview:EffectPreviewControl}}" />
            </Border.Effect>
        </Border>
    </Border>
</UserControl>
